#!/bin/sh

PATH="/usr/sbin:/usr/bin:/sbin:/bin"
export LC_ALL=C PATH
unset IFS
set -u

readonly CONF_FILE="/etc/config/bot.conf"

if [ -f "$CONF_FILE" ]; then
    # shellcheck disable=SC2012
    _conf_meta=$(ls -n "$CONF_FILE" 2>/dev/null | awk 'NR==1 {printf "%s:%s", $3, $1}') &&
        [ -n "$_conf_meta" ] || {
        printf 'FATAL: Cannot read metadata of %s\n' "$CONF_FILE" >&2
        exit 1
    }
    case "$_conf_meta" in
    0:-rw-------* | 0:-r--------*) ;;
    *)
        printf 'FATAL: %s must be owned by root (uid 0) with mode 600 or 400 (got %s)\n' "$CONF_FILE" "$_conf_meta" >&2
        exit 1
        ;;
    esac

    . "$CONF_FILE" || {
        printf '[Error] Failed to source config\n' >&2
        exit 1
    }

    MATRIX_URL="${MATRIX_URL:-}"
    MATRIX_URL="${MATRIX_URL%/}"
    MATRIX_ACCESS_TOKEN="${MATRIX_ACCESS_TOKEN:-}"
    MATRIX_ROOM_IDS="${MATRIX_ROOM_IDS:-}"
    SSH_HOST="${SSH_HOST:-}"
    SSH_PORT="${SSH_PORT:-}"
    SSH_USER="${SSH_USER:-}"
    SSH_KEY="${SSH_KEY:-}"
    readonly MATRIX_URL MATRIX_ACCESS_TOKEN MATRIX_ROOM_IDS \
        SSH_HOST SSH_PORT SSH_USER SSH_KEY

    if [ -z "$MATRIX_URL" ] || [ -z "$MATRIX_ACCESS_TOKEN" ]; then
        printf '[Error] MATRIX_URL or MATRIX_ACCESS_TOKEN missing in config\n' >&2
        exit 1
    fi
else
    printf "[Error] Config file not found: %s\n" "$CONF_FILE" >&2
    exit 1
fi

DEBUG_MODE=0
MODE="auto"
RAW_TARGET_ROOM=""
FORCE_WGET=0
FORCE_FALLBACK=0

while [ $# -gt 0 ]; do
    case "$1" in
    -d | --debug)
        DEBUG_MODE=1
        shift
        ;;
    --ssh-only)
        MODE="ssh"
        shift
        ;;
    --http-only)
        MODE="http"
        shift
        ;;
    --no-e2ee)
        MODE="http"
        shift
        ;;
    --force-wget)
        FORCE_WGET=1
        shift
        ;;
    --force-fallback)
        FORCE_FALLBACK=1
        shift
        ;;
    --room-id)
        if [ -n "$2" ] && [ "${2#-}" = "$2" ]; then
            RAW_TARGET_ROOM="$2"
            shift 2
        else
            printf '[Error] --room-id requires an argument\n' >&2
            exit 1
        fi
        ;;
    --)
        shift
        break
        ;;
    -*)
        printf "Unknown option: %s\n" "$1" >&2
        exit 1
        ;;
    *) break ;;
    esac
done

MSG="$*"

if [ -z "$MSG" ]; then
    printf '[Error] No message provided\n' >&2
    exit 1
fi

debug_echo() { [ "$DEBUG_MODE" -eq 1 ] && printf "[Debug] %s\n" "$1"; }

if [ -z "$RAW_TARGET_ROOM" ]; then
    set -f
    # shellcheck disable=SC2086
    set -- $MATRIX_ROOM_IDS
    set +f
    RAW_TARGET_ROOM="${1:-}"
    if [ -z "$RAW_TARGET_ROOM" ]; then
        printf '[Error] No room ID specified and MATRIX_ROOM_IDS is empty in config\n' >&2
        exit 1
    fi
fi

TARGET_ROOM=$(printf '%s' "$RAW_TARGET_ROOM" | tr -cd 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.:_!#=-')

if [ -z "$TARGET_ROOM" ]; then
    printf '[Error] Invalid or empty room ID after sanitization\n' >&2
    exit 1
fi

ENCODED_ROOM=$(printf '%s' "$TARGET_ROOM" | sed 's/#/%23/g; s/!/%21/g')

PLAIN_TEXT=$(printf '%s' "$MSG" | sed 's/<[bB][rR][^>]*>/\n/g; s/<[^>]*>//g')

if [ "$DEBUG_MODE" -eq 1 ]; then
    printf '%s\n' "--- PREPARED DATA ---"
    printf 'Notification Body (Plain):\n%s\n' "$PLAIN_TEXT"
    printf '%s\n' "-----------------------"
    printf 'Room Message (HTML):\n%s\n' "$MSG"
    printf '%s\n' "-----------------------"
fi

if [ "$FORCE_FALLBACK" -eq 0 ] && command -v jq >/dev/null 2>&1; then
    debug_echo "JSON Strategy: JQ (Best Practice)"
    JSON_PAYLOAD=$(jq -n --arg b "$PLAIN_TEXT" --arg f "$MSG" \
        '{msgtype: "m.text", body: $b, format: "org.matrix.custom.html", formatted_body: $f}')
else
    if [ "$FORCE_FALLBACK" -eq 1 ]; then
        debug_echo "JSON Strategy: Native (awk fallback) [FORCED]"
    else
        debug_echo "JSON Strategy: Native (awk fallback)"
    fi

    # shellcheck disable=SC2016
    AWK_ESC='{ gsub(/\\/, "\\\\"); gsub(/"/, "\\\""); if (NR > 1) printf "\\n"; printf "%s", $0 }'
    ESC_PLAIN=$(printf '%s' "$PLAIN_TEXT" | awk "$AWK_ESC")
    ESC_HTML=$(printf '%s' "$MSG" | awk "$AWK_ESC")
    JSON_PAYLOAD="{\"msgtype\":\"m.text\",\"body\":\"$ESC_PLAIN\",\"format\":\"org.matrix.custom.html\",\"formatted_body\":\"$ESC_HTML\"}"
fi

try_ssh() {
    if [ -z "$SSH_HOST" ] || [ -z "$SSH_KEY" ]; then
        debug_echo "SSH not configured (missing SSH_HOST or SSH_KEY)"
        return 1
    fi

    if [ -z "$SSH_USER" ] || [ -z "$SSH_PORT" ]; then
        debug_echo "SSH config incomplete (missing SSH_USER or SSH_PORT)"
        return 1
    fi

    if [ ! -r "$SSH_KEY" ]; then
        debug_echo "SSH key not found or not readable: $SSH_KEY"
        [ "$MODE" = "ssh" ] && printf '[Error] SSH key not accessible: %s\n' "$SSH_KEY" >&2
        return 1
    fi

    debug_echo "Attempting SSH -> Room: $TARGET_ROOM"

    printf "%s" "$MSG" | ssh -i "$SSH_KEY" -p "$SSH_PORT" \
        -o StrictHostKeyChecking=yes \
        -o UserKnownHostsFile=/etc/matrix_bot_known_hosts \
        -o LogLevel=ERROR \
        -o BatchMode=yes \
        -o ConnectTimeout=10 \
        -o ServerAliveInterval=5 \
        -o ServerAliveCountMax=2 \
        -T \
        "$SSH_USER@$SSH_HOST" matrix-commander-rs --room "'$TARGET_ROOM'" --html --message - >/dev/null 2>&1

    # shellcheck disable=SC2181
    if [ $? -eq 0 ]; then
        debug_echo "Transport: SSH (Success)"
        return 0
    fi
    return 1
}

if [ "$MODE" != "http" ]; then
    if try_ssh; then
        exit 0
    fi
    if [ "$MODE" = "ssh" ]; then
        printf '[Error] SSH transport failed and --ssh-only was specified\n' >&2
        exit 1
    fi
    debug_echo "SSH failed or skipped, fallback to HTTP..."
fi

debug_echo "HTTP -> Room: $TARGET_ROOM"

FULL_URL="$MATRIX_URL/_matrix/client/v3/rooms/$ENCODED_ROOM/send/m.room.message"

HDR_FILE="/tmp/mhdr_$$.tmp"
BODY_FILE="/tmp/mbody_$$.tmp"
WGET_CONF="/tmp/mwgetrc_$$.tmp"
trap 'rm -f "$HDR_FILE" "$BODY_FILE" "$WGET_CONF"' EXIT INT TERM

(umask 177 && set -C && : >"$HDR_FILE" && : >"$BODY_FILE" && : >"$WGET_CONF") || {
    printf '[Error] Failed to create temp files in /tmp\n' >&2
    exit 1
}
printf 'header = "Authorization: Bearer %s"\n' "$MATRIX_ACCESS_TOKEN" >"$HDR_FILE"
printf '%s' "$JSON_PAYLOAD" >"$BODY_FILE"
printf 'header = Authorization: Bearer %s\n' "$MATRIX_ACCESS_TOKEN" >"$WGET_CONF"

if [ "$FORCE_WGET" -eq 0 ] && command -v curl >/dev/null 2>&1; then
    debug_echo "Transport: CURL"
    curl -s -f -X POST "$FULL_URL" \
        -K "$HDR_FILE" \
        -H "Content-Type: application/json" \
        -d "$JSON_PAYLOAD" \
        --connect-timeout 10 \
        --max-time 30 >/dev/null
    exit $?
elif command -v wget >/dev/null 2>&1; then
    if [ "$FORCE_WGET" -eq 1 ]; then
        debug_echo "Transport: WGET [FORCED]"
    else
        debug_echo "Transport: WGET"
    fi
    WGETRC="$WGET_CONF" wget -q -O /dev/null \
        --header "Content-Type: application/json" \
        --post-file "$BODY_FILE" \
        --timeout=30 \
        "$FULL_URL"
    exit $?
fi

printf '[Error] No HTTP client available (curl or wget required)\n' >&2
exit 1
