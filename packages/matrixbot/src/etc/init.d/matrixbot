#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

NAME="matrixbot"
PROG="/usr/lib/lua/matrixbot/main.lua"

BOOTING=0

boot() {
    BOOTING=1
    start
}

start_service() {
    if ! /usr/bin/lua -e "if not require('matrixbot.config').load() then os.exit(1) end"; then
        logger -t "$NAME" "Service start aborted due to configuration errors."
        return 1
    fi

    local delay=0
    if [ "$BOOTING" = "1" ]; then
        delay="$(uci -q get matrixbot.main.start_delay || printf '30')"
    fi

    procd_open_instance
    if [ -n "$delay" ] && [ "$delay" -gt 0 ] 2>/dev/null; then
        procd_set_param command /bin/sh -c "sleep $delay && exec /usr/bin/lua \"$PROG\""
    else
        procd_set_param command /usr/bin/lua "$PROG"
    fi
    procd_set_param respawn 3600 60 12
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "matrixbot"
}

reload_service() {
    stop
    start
}

stop_service() {
    if [ -f "/var/run/matrixbot_ssh.pid" ]; then
        logger -t "$NAME" "Stopping Matrix Bot (E2EE)..."
    else
        logger -t "$NAME" "Stopping Matrix Bot (HTTP)..."
    fi
    
    if [ -f "/var/run/matrixbot_poller.pid" ]; then
        local ppid
        ppid=$(cat /var/run/matrixbot_poller.pid)
        [ -n "$ppid" ] && kill -TERM "$ppid" 2>/dev/null
    fi
    
    if [ -f "/var/run/matrixbot_ssh.pid" ]; then
        local spid
        spid=$(cat /var/run/matrixbot_ssh.pid)
        [ -n "$spid" ] && kill -TERM "$spid" 2>/dev/null
    fi
    
    sleep 1
    
    if [ -f "/var/run/matrixbot_poller.pid" ]; then
        local ppid
        ppid=$(cat /var/run/matrixbot_poller.pid)
        [ -n "$ppid" ] && kill -9 "$ppid" 2>/dev/null
        rm -f /var/run/matrixbot_poller.pid
    fi

    if [ -f "/var/run/matrixbot_ssh.pid" ]; then
        local spid
        spid=$(cat /var/run/matrixbot_ssh.pid)
        [ -n "$spid" ] && kill -9 "$spid" 2>/dev/null
        rm -f /var/run/matrixbot_ssh.pid
    fi
}
