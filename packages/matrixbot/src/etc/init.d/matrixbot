#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

NAME="matrixbot"
PROG="/usr/lib/lua/matrixbot/main.lua"

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/env lua "$PROG"
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

service_triggers() {
    procd_add_reload_trigger "matrixbot"
}

reload_service() {
    stop
    start
}

stop_service() {
    if [ -f "/var/run/matrixbot_ssh.pid" ]; then
        logger -t "$NAME" "Stopping Matrix Bot (E2EE)..."
    else
        logger -t "$NAME" "Stopping Matrix Bot (HTTP)..."
    fi
    
    if [ -f "/var/run/matrixbot_poller.pid" ]; then
        local ppid
        ppid=$(cat /var/run/matrixbot_poller.pid)
        [ -n "$ppid" ] && kill -TERM "$ppid" 2>/dev/null
    fi
    
    if [ -f "/var/run/matrixbot_ssh.pid" ]; then
        local spid
        spid=$(cat /var/run/matrixbot_ssh.pid)
        [ -n "$spid" ] && kill -TERM "$spid" 2>/dev/null
    fi
    
    sleep 1
    
    if [ -f "/var/run/matrixbot_poller.pid" ]; then
        local ppid
        ppid=$(cat /var/run/matrixbot_poller.pid)
        [ -n "$ppid" ] && kill -9 "$ppid" 2>/dev/null
        rm -f /var/run/matrixbot_poller.pid
    fi

    if [ -f "/var/run/matrixbot_ssh.pid" ]; then
        local spid
        spid=$(cat /var/run/matrixbot_ssh.pid)
        [ -n "$spid" ] && kill -9 "$spid" 2>/dev/null
        rm -f /var/run/matrixbot_ssh.pid
    fi
}
