config matrixbot 'main'
	option url 'https://matrix-example.tld'
	option token 'syt_...'
	list rooms '!AbCdEfGhIj:matrix-example.tld'
	option admin_room '!UvWxYzAbCd:matrix-example.tld'
	option bot_user '@mybot:matrix-example.tld'
	option admin_user '@me:matrix-example.com'

config matrixbot 'e2ee'
	option enabled '0'
	option ssh_host '192.168.1.100'
	option ssh_port '22'
	option ssh_user 'myuser'
	option ssh_key '/root/.ssh/router-matrix'
	option data_dir '/home/bot/.config/matrix-cli'

config matrixbot 'features'
	list svc_wanted 'dnsmasq'
	list svc_wanted 'firewall'
	list svc_wanted 'network'
	list svc_wanted 'odhcpd'
	list svc_wanted 'cron'
	list svc_wanted 'uhttpd'
	list svc_wanted 'nginx'
	option mac_pc ''
	list wol_interfaces 'br-lan'
	option wifi_detailed '0'
	option wifi_show_key '0'
