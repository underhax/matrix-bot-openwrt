#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

SCRIPT="/usr/lib/matrix/matrix_bot_http"

start_service() {
    if [ ! -f "$SCRIPT" ]; then
        logger -t matrixbot_http "ERROR: $SCRIPT not found, refusing to start"
        return 1
    fi

    procd_open_instance
    procd_set_param command /bin/sh "$SCRIPT"

    procd_set_param respawn 3600 5 0

    procd_set_param stdout 1
    procd_set_param stderr 1

    procd_close_instance
}

stop_service() {
    logger -t matrixbot_http "Stopping matrixbot_http"
}
